# =============================================================================
# Supabase-Zugangsdaten für FisherTechService Community-Austausch
#
# Diese Variablen werden im Astro-Frontend via import.meta.env gelesen.
# Werte findest du im Supabase Dashboard unter: Project Settings → API
#
# SICHERHEIT:
#   PUBLIC_SUPABASE_URL und PUBLIC_SUPABASE_ANON_KEY sind öffentlich –
#   sie dürfen im Browser sichtbar sein. Sicherheit läuft über Row Level
#   Security (RLS) auf Datenbankebene.
#
#   SUPABASE_SERVICE_ROLE_KEY umgeht RLS vollständig und darf NIEMALS
#   ins Frontend oder in einen öffentlichen Repository!
# =============================================================================

# Projekt-URL (öffentlich – darf im Frontend verwendet werden)
PUBLIC_SUPABASE_URL=https://dein-projekt-id.supabase.co

# Anonymer API-Schlüssel (öffentlich – darf im Frontend verwendet werden)
# Gibt ohne Login nur Lesezugriff auf öffentlich konfigurierte Tabellen.
PUBLIC_SUPABASE_ANON_KEY=dein-anon-schluessel-hier

# Service-Role-Schlüssel (GEHEIM – nur für serverseitige Skripte/Admin-Tools)
# Niemals im Frontend verwenden! Nie in Git committen!
# SUPABASE_SERVICE_ROLE_KEY=dein-service-role-schluessel-hier
