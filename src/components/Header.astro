---
import FisherLogo from "../Photos/FisherTechService.jpeg?url";

const base = '/';
---

<header>
  <div class="site-header__inner">
    <a class="brand" href={base} aria-label="FisherTechService Startseite">
      <img src={FisherLogo} alt="" class="logo">
      <span class="brand__text">
        <strong>FisherTechService</strong>
        <small>Service. Präzision. Leidenschaft.</small>
      </span>
    </a>
  <nav aria-label="Hauptnavigation">
    <ul class="main-nav">
      <li>
        <a href={base}>Home</a>
        <ul class="dropdown">
          <li><a href={`${base}#services`}>Services</a></li>
          <li><a href={`${base}#kontakt`}>Kontakt</a></li>
        </ul>
      </li>


      <li>
        <a href={`${base}uns`}>Über Uns</a>
        <ul class="dropdown">
          <li><a href={`${base}uns#team`}>Team</a></li>
        </ul>
      </li>


      <li>
        <a href={`${base}projekt`}>Mehr</a>
        <ul class="dropdown">
          <li><a href={`${base}projekt`}>Übersicht</a></li>
          <li><a href={`${base}austausch`}>Austausch</a></li>
          <li><a href={`${base}fragen`}>Fragen</a></li>
          <li><a href={`${base}galerie`}>Galerie</a></li>
        </ul>
      </li>
    </ul>
  </nav>
    <a class="header-cta" href={`${base}#kontakt`}>Service anfragen</a>
  </div>
</header>
