---
const legalLinks = [
  { href: '/datenschutz', label: 'Datenschutz' },
  { href: '/impressum', label: 'Impressum' },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <strong>FisherTechService</strong>
      <p>Technischer Service für Angelruten und Rollen – sorgfältig, persönlich und zuverlässig.</p>
    </div>
    <div class="site-footer__contact">
      <span>Kontakt</span>
      <a href="mailto:info@fishertechservice.ch">info@fishertechservice.ch</a>
      <a href="tel:+41765671007">+41 76 567 10 07</a>
    </div>
    <nav class="site-footer__nav" aria-label="Rechtliche Links">
      <span>Informationen</span>
      <ul class="site-footer__legal-links">
        {legalLinks.map((link) => (
          <li>
            <a href={link.href}>{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
  <div class="site-footer__bottom">&copy; 2026 Fischer Tech Service · V. Ivic &amp; D. Ivic</div>
</footer>
