---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RollenBild1 from "../Photos/RollenBild1.png?url";
import "../assets/style.scss";
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
  <link rel="icon" type="image/png" href="/favicon.png?v=3" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />
  <title>Projekt | FisherTechService</title>
</head>
<body>
  <Header />
  <main>
    <section class="subpage-hero project-page">
      <span class="eyebrow">Community · Übersicht</span>
      <h2>Wissen, Erfahrungen und besondere Momente teilen.</h2>
      <p class="section-intro">Wähle den Bereich, der dich interessiert. Finde Antworten auf häufige Fragen rund um Wartung, Reparatur und Tuning oder entdecke Bilder aus unserer Werkstatt und vom Wasser.</p>

      <figure class="project-visual">
        <img src={RollenBild1} alt="Servicearbeiten an einer Angelrolle" loading="lazy" />
      </figure>

      <div class="project-grid">
        {/* Austausch-Seite vorerst ausgeblendet
        <a class="project-card" href="/austausch">
          <span class="project-card__icon" aria-hidden="true">↔</span><span class="project-card__number">01</span>
          <h3>Austausch</h3><p>Erfahrungen teilen, diskutieren und voneinander lernen.</p>
          <span class="project-card__link">Zum Austausch →</span>
        </a>
        */}
        <a class="project-card" href="/fragen">
          <span class="project-card__icon" aria-hidden="true">?</span><span class="project-card__number">01</span>
          <h3>Fragen</h3><p>Antworten rund um Wartung, Reparatur und Tuning finden.</p>
          <span class="project-card__link">Zu den Fragen →</span>
        </a>
        <a class="project-card project-card--accent" href="/galerie">
          <span class="project-card__icon" aria-hidden="true">◇</span><span class="project-card__number">02</span>
          <h3>Galerie</h3><p>Einblicke in unsere Arbeit, Projekte und Erlebnisse am Wasser.</p>
          <span class="project-card__link">Zur Galerie →</span>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</body>
</html>
