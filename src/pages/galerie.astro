---
import DIvicP1 from "../Photos/D.Ivic_P1.jpeg?url";
import DIvicP2 from "../Photos/D.Ivic_P2.jpeg?url";
import DIvicP3 from "../Photos/D.Ivic_P3.jpeg?url";
import DIvicP4 from "../Photos/D.Ivic_P4.jpeg?url";
import ServiceArbeiten1 from "../Photos/ServiceArbeiten1.jpeg?url";
import ServiceArbeiten2 from "../Photos/ServiceArbeiten2.jpeg?url";
import RollenBild1 from "../Photos/RollenBild1.png?url";
import RollenBild2 from "../Photos/RollenBild2.png?url";
import RollenBild3 from "../Photos/RollenBild3.png?url";
import RollenBild4 from "../Photos/RollenBild4.png?url";
import Layout from "../layouts/Layout.astro";

const images = [
  { src: ServiceArbeiten1, alt: "Servicearbeiten an Angelausrüstung", label: "Werkstatt" },
  { src: DIvicP3, alt: "Fischer mit einem Fang", label: "Am Wasser" },
  { src: DIvicP1, alt: "FisherTechService Projekt", label: "Leidenschaft" },
  { src: ServiceArbeiten2, alt: "Präzise Arbeiten in der Werkstatt", label: "Service" },
  { src: DIvicP4, alt: "Team von FisherTechService", label: "Team" },
  { src: DIvicP2, alt: "Angelerlebnis am Wasser", label: "Erlebnis" },
  { src: RollenBild1, alt: "Detailarbeit an einer Angelrolle", label: "Detailarbeit" },
  { src: RollenBild2, alt: "Gewartete Angelrollen mit Werkzeug", label: "Wartung" },
  { src: RollenBild3, alt: "Servicearbeiten an einer Angelrolle", label: "Präzision" },
  { src: RollenBild4, alt: "Optimierte Angelrolle nach dem Service", label: "Tuning" },
];
---

<Layout title="Galerie">
  <main>
    <section class="gallery-intro">
      <span class="eyebrow">Community · Galerie</span>
      <h2>Zwischen Werkbank und Wasser.</h2>
      <p class="section-intro">Einblicke in unsere Arbeit, unsere Leidenschaft und die Momente, für die sich sorgfältiger Service lohnt.</p>
      <div class="gallery-grid">
        {images.map((image, index) => (
          <figure class:list={["gallery-item", { "gallery-item--wide": index === 0 || index === 5 }]}>
            <img src={image.src} alt={image.alt} loading="lazy">
            <figcaption>{image.label}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  </main>
</Layout>
