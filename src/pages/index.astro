---
import DIvicP3 from "../Photos/D.Ivic_P3.jpeg?url";
import ServiceArbeiten1 from "../Photos/ServiceArbeiten1.jpeg?url";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../assets/style.scss";
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FisherTechService</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
     integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
     crossorigin=""/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
     integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
     crossorigin=""></script>
</head>
<body>
  <Header />

  <main>
    <section class="hero">
      <span class="eyebrow">Schweizer Familienunternehmen</span>
      <h2 class="hero-title">Service, auf den du dich verlassen kannst.</h2>
      <figure class="hero__visual">
        <img src={DIvicP3} alt="Fischer Tech Service Team">
      </figure>
      <div class="hero__content">
        <p class="hero__lead">
          Wartung, Reparatur und Optimierung für Angelruten und Rollen – präzise ausgeführt und persönlich betreut.
        </p>
        <div class="hero__actions">
          <a class="button-primary" href="/about#kontakt">Service anfragen</a>
          <a class="button-secondary" href="/about#services">Leistungen entdecken</a>
        </div>
      </div>
    </section>

    <section id="kennzahlen" class="section">
      <span class="eyebrow">Was uns auszeichnet</span>
      <h2>Erfahrung, die man spürt</h2>
      <div class="columns is-multiline is-centered">
        <div class="column is-3">
          <div class="box has-text-centered">
            <p class="title is-1 has-text-primary">3+</p>
            <p class="subtitle is-5">Jahre Erfahrung</p>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered">
            <p class="title is-1 has-text-primary">3</p>
            <p class="subtitle is-5">Service-Angebote</p>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered">
            <p class="title is-1 has-text-primary">45+</p>
            <p class="subtitle is-5">Zufriedene Kunden</p>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered">
            <p class="title is-1 has-text-primary">72+</p>
            <p class="subtitle is-5">Reparierte Rollen</p>
          </div>
        </div>
      </div>
    </section>
    
    <section id="social-media">
      <span class="eyebrow">Einblicke in unsere Arbeit</span>
      <h2>Folge uns am Wasser und in der Werkstatt</h2>
      <div class="social-media-container">
        <div class="social-links">
          <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" class="social-icon instagram">
            <span>Instagram</span>
          </a>
          <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="social-icon facebook">
            <span>Facebook</span>
          </a>
          <a href="https://www.tiktok.com" target="_blank" rel="noopener noreferrer" class="social-icon tiktok">
            <span>TikTok</span>
          </a>
          <a href="https://www.youtube.com" target="_blank" rel="noopener noreferrer" class="social-icon youtube">
            <span>YouTube</span>
          </a>
        </div>
        <figure class="social-image">
          <img src={ServiceArbeiten1} alt="Service Arbeiten">
        </figure>
      </div>
    </section>
    
    <section id="location">
      <span class="eyebrow">Direkt vor Ort</span>
      <h2>Du findest uns in Zürich</h2>
      <div id="map"></div>
    </section>
  </main>

  <script>
    // Warte bis Seite und Leaflet vollständig geladen sind
    window.addEventListener('load', function() {
      // @ts-ignore - Leaflet wird via CDN geladen
      // Leaflet Karte initialisieren - Bürkliplatz Zürich
      const map = L.map('map').setView([47.3636, 8.5391], 15);
      
      // @ts-ignore
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
      }).addTo(map);
      
      // @ts-ignore
      L.marker([47.3636, 8.5391]).addTo(map)
        .bindPopup('<b>Fischer Tech Service</b><br>Bürkliplatz, Zürich')
        .openPopup();
    });
  </script>

  <Footer />
</body>
</html>
