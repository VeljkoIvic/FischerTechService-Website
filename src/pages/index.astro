---
import DIvicP3 from "../Photos/D.Ivic_P3.jpeg?url";
import ServiceArbeiten1 from "../Photos/ServiceArbeiten1.jpeg?url";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../assets/style.scss";
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FisherTechService</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
     integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
     crossorigin=""/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
     integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
     crossorigin=""></script>
</head>
<body>
  <Header />

  <main>
    <section class="hero">
      <span class="eyebrow">Schweizer Familienunternehmen</span>
      <h2 class="hero-title">Service, auf den du dich verlassen kannst.</h2>
      <figure class="hero__visual">
        <img src={DIvicP3} alt="Fischer Tech Service Team">
      </figure>
      <div class="hero__content">
        <p class="hero__lead">
          Wartung, Reparatur und Optimierung für Angelruten und Rollen – präzise ausgeführt und persönlich betreut.
        </p>
        <div class="hero__actions">
          <a class="button-primary" href="/about#kontakt">Service anfragen</a>
          <a class="button-secondary" href="/about#services">Leistungen entdecken</a>
        </div>
      </div>
    </section>
    
  <Footer />
</body>
</html>
