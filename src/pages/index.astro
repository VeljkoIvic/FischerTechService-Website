  <script>
    // Warte bis Seite und Leaflet vollständig geladen sind
    window.addEventListener('load', function() {
      // @ts-ignore - Leaflet wird via CDN geladen
      // Leaflet Karte initialisieren - Bürkliplatz Zürich
      const map = L.map('map').setView([47.3636, 8.5391], 15);
      
      // @ts-ignore
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
      }).addTo(map);
      
      // @ts-ignore
      L.marker([47.3636, 8.5391]).addTo(map)
        .bindPopup('<b>Fischer Tech Service</b><br>Bürkliplatz, Zürich')
        .openPopup();
    });
  </script>

