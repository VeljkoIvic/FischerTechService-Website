---
import DIvicP3 from "../Photos/D.Ivic_P3.jpeg?url";
import ServiceArbeiten2 from "../Photos/ServiceArbeiten2.jpeg?url";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../assets/style.scss";
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FisherTechService</title>
</head>
<body>
  <Header />

  <main>
    <section id="start" class="hero">
      <span class="eyebrow">Schweizer Familienunternehmen</span>
      <h2 class="hero-title">Service, auf den du dich verlassen kannst.</h2>
      <figure class="hero__visual">
        <!-- <img src={DIvicP3} alt="Fischer Tech Service Team"> -->
      </figure>
      <div class="hero__content">
        <p class="hero__lead">
          Wartung, Reparatur und Optimierung für Angelruten und Rollen – präzise ausgeführt und persönlich betreut.
        </p>
        <div class="hero__actions">
          <a class="button-primary" href="#kontakt">Service anfragen</a>
          <a class="button-secondary" href="#services">Leistungen entdecken</a>
        </div>
      </div>
    </section>

    <section id="services" class="services-section">
      <span class="eyebrow">Werkstatt &amp; Know-how</span>
      <h2>Services</h2>

      <figure class="float-right">
        <img src={ServiceArbeiten2} alt="Servicearbeiten an Angelausrüstung">
      </figure>

      <p>
        Bei Fischer Tech Service dreht sich alles um Präzision, Qualität und Leidenschaft fürs Angeln.
        Wir bieten einen umfassenden Service für Wartung, Reparatur, Tuning und Individualisierung
        von Angelruten und Rollen.
      </p>
      <p>
        Jede Rute und jede Rolle wird sorgfältig geprüft, fachgerecht instand gesetzt und bei Bedarf
        optimiert. Ob regelmässiger Service, gezielte Reparatur oder individuelles Custom-Build:
        Wir behandeln deine Ausrüstung, als wäre es unsere eigene.
      </p>
      <p>
        Von der einfachen Reinigung bis zur kompletten Überholung ist deine Ausrüstung bei uns in
        den besten Händen. Alle Preise verstehen sich zuzüglich Materialkosten und Inspektion.
      </p>
    </section>

    <section id="kontakt" class="contact-section">
      <span class="eyebrow contact-heading">Persönlich für dich da</span>
      <h2 class="contact-heading">Kontakt</h2>
      <p class="contact-intro">
        Hast du Fragen zu unseren Services oder möchtest du einen Termin vereinbaren?
        Fülle das Formular aus und wir melden uns schnellstmöglich bei dir.
      </p>

      <form action="https://formsubmit.co/fishertechservice@gmail.com" method="POST" class="contact-form">
        <input type="hidden" name="_subject" value="Neue Kontaktanfrage von FisherTechService">
        <input type="hidden" name="_captcha" value="true">
        <input type="hidden" name="_template" value="table">

        <div class="form-group">
          <label class="sr-only" for="name">Vorname und Nachname</label>
          <input type="text" id="name" name="name" required placeholder="Vorname / Nachname">
        </div>
        <div class="form-group">
          <label class="sr-only" for="email">E-Mail</label>
          <input type="email" id="email" name="email" required placeholder="E-Mail">
        </div>
        <div class="form-group">
          <label class="sr-only" for="phone">Telefon</label>
          <input type="tel" id="phone" name="phone" placeholder="Telefon">
        </div>
        <div class="form-group">
          <label class="sr-only" for="service">Service wählen</label>
          <select id="service" name="service">
            <option value="" selected>Service wählen</option>
            <option value="Reparatur">Reparatur</option>
            <option value="Tuning">Tuning</option>
            <option value="Beratung">Beratung</option>
          </select>
        </div>
        <div class="form-group">
          <label class="sr-only" for="message">Bemerkungen</label>
          <textarea id="message" name="message" rows="6" required placeholder="Bemerkungen"></textarea>
        </div>
        <div class="form-group">
          <button type="submit" class="submit-btn">Anfrage senden</button>
        </div>
      </form>
    </section>

    <section id="partner" class="partner-section" aria-labelledby="partner-title">
      <span class="eyebrow">Gemeinsam stark</span>
      <h2 id="partner-title">Partner</h2>
      <a class="partner-card" href="https://www.mickeys-tackle.ch/de/home.html" target="_blank" rel="noopener noreferrer">
        <span>
          <strong>Mickey's Tackle</strong>
          <small>Angelgeräte, Zubehör und Beratung</small>
        </span>
        <span class="partner-card__link">Partnerseite besuchen →</span>
      </a>
    </section>
  </main>

  <Footer />
</body>
</html>
