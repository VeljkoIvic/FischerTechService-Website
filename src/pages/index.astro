---
import DIvicP3 from "../Photos/D.Ivic_P3.jpeg";
import ServiceArbeiten1 from "../Photos/ServiceArbeiten1.jpeg";
import FisherLogo from "../Photos/FisherTechService.jpeg";
import "../assets/style.scss";

const base = '/';
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FisherTechService</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
     integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
     crossorigin=""/>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
     integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
     crossorigin=""></script>
</head>
<body>
  <header>
    <div class="header-container">
      <img src={FisherLogo.src} alt="FisherTechService Logo" class="logo">
      <h1>FisherTechService</h1>
    </div>
    <nav>
      <ul class="main-nav">
        <li>
          <a href={base}>Home</a>
          <ul class="dropdown">
            <li><a href={`${base}#start`}>Willkommen</a></li>
            <li><a href={`${base}#kennzahlen`}>Kennzahlen</a></li>
            <li><a href={`${base}#social-media`}>Social Media</a></li>
            <li><a href={`${base}#location`}>Karte</a></li>
          </ul>
        </li>
        <li>
          <a href={`${base}about`}>Services</a>
          <ul class="dropdown">
            <li><a href={`${base}about#services`}>Services</a></li>
            <li><a href={`${base}about#kontakt`}>Kontakt</a></li>
          </ul>
        </li>
        <li>
          <a href={`${base}uns`}>Über Uns</a>
          <ul class="dropdown">
            <li><a href={`${base}uns#team`}>Team</a></li>
            <li><a href={`${base}uns#video`}>Video</a></li>
          </ul>
        </li>
        <li>
          <a href={`${base}projekt`}>Projekt</a>
          <ul class="dropdown">
            <li><a href={`${base}projekt#overview`}>Überblick</a></li>
            <li><a href={`${base}projekt#details`}>Fachbegriffe</a></li>
            <li><a href={`${base}projekt#community`}>Community</a></li>
          </ul>
        </li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="hero">
      <h2 class="hero-title">Willkommen bei FisherTechService</h2>
      <figure>
        <img src={DIvicP3.src} alt="Fischer Tech Service Team">
      </figure>
      <div>
        <p>
          FisherTechService steht für präzisen Service, echte Leidenschaft und technische Kompetenz rund um Angelruten und Rollen.
          Wir kümmern uns um Wartung, Reparatur und Optimierung, damit dein Equipment zuverlässig funktioniert, wenn es darauf ankommt.
        </p> 

        <p> 
          Mit viel Erfahrung, hochwertigen Ersatzteilen und Liebe zum Detail sorgen wir dafür,
          dass deine Ausrüstung in bestem Zustand bleibt, vom einfachen Service bis zur individuellen Lösung.
        </p> 
          Technik. Erfahrung. Leidenschaft fürs Angeln.
        </p>
      </div>
    </section>

    <section id="kennzahlen" class="section">
      <h2>Kennzahlen</h2>
      <div class="columns is-multiline is-centered">
        <div class="column is-3">
          <div class="box has-text-centered">
            <p class="title is-1 has-text-primary">3+</p>
            <p class="subtitle is-5">Jahre Erfahrung</p>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered">
            <p class="title is-1 has-text-primary">5</p>
            <p class="subtitle is-5">Service-Angebote</p>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered">
            <p class="title is-1 has-text-primary">45+</p>
            <p class="subtitle is-5">Zufriedene Kunden</p>
          </div>
        </div>
        <div class="column is-3">
          <div class="box has-text-centered">
            <p class="title is-1 has-text-primary">60+</p>
            <p class="subtitle is-5">Reparierte Rollen</p>
          </div>
        </div>
      </div>
    </section>
    
    <section id="social-media">
      <h2>Social Media</h2>
      <div class="social-media-container">
        <div class="social-links">
          <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" class="social-icon instagram">
            <span>Instagram</span>
          </a>
          <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="social-icon facebook">
            <span>Facebook</span>
          </a>
          <a href="https://www.tiktok.com" target="_blank" rel="noopener noreferrer" class="social-icon tiktok">
            <span>TikTok</span>
          </a>
          <a href="https://www.youtube.com" target="_blank" rel="noopener noreferrer" class="social-icon youtube">
            <span>YouTube</span>
          </a>
        </div>
        <figure class="social-image">
          <img src={ServiceArbeiten1.src} alt="Service Arbeiten">
        </figure>
      </div>
    </section>
    
    <section id="location">
      <h2>Kartenansicht</h2>
      <div id="map"></div>
    </section>
  </main>

  <script>
    // Warte bis Seite und Leaflet vollständig geladen sind
    window.addEventListener('load', function() {
      // @ts-ignore - Leaflet wird via CDN geladen
      // Leaflet Karte initialisieren - Bürkliplatz Zürich
      const map = L.map('map').setView([47.3636, 8.5391], 15);
      
      // @ts-ignore
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
      }).addTo(map);
      
      // @ts-ignore
      L.marker([47.3636, 8.5391]).addTo(map)
        .bindPopup('<b>Fischer Tech Service</b><br>Bürkliplatz, Zürich')
        .openPopup();
    });
  </script>

  <footer style="clear: both;">
    <p>&copy; 2026 Fischer Tech Service | V. Ivic &amp; D. Ivic | Schweiz</p>
    <p><a href="mailto:info@fishertechservice.ch">info@fischertechservice.ch</a> | Tel: +41 76 567 10 07</p>
  </footer>
</body>
</html>
